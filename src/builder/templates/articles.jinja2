{% extends "_layouts/base.jinja2" %}

{% block title %}Articles | Mario-César Señoranis{% endblock %}
{% block extrahead -%}
  <meta name="description" content="{{ page.description }}" />
  <link rel="canonical" href="{{ canonical_url(site, page) }}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ page.title }} | Mario-César Señoranis" />
  <meta property="og:description" content="{{ page.description }}" />
  <meta property="og:url" content="{{ canonical_url(site, page) }}" />
  <meta property="og:image" content="{{ site.image_url }}" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ page.title }} | Mario-César Señoranis" />
  <meta name="twitter:description" content="{{ page.description }}" />
  <meta name="twitter:image" content="{{ site.image_url }}" />
{%- endblock %}

{% block body -%}
  <section class="articles-index" aria-labelledby="articles-heading">
    <div class="page-heading">
      <h1 id="articles-heading">Articles</h1>
      <p>Notes on software, systems, and the useful edges between product work and engineering practice.</p>
    </div>
    <div class="article-list">
      {% for article in articles %}
      <article class="article-card">
        <time datetime="{{ article.lastmod.isoformat() }}">{{ display_date(article.lastmod) }}</time>
        <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
        {% if article.summary -%}
        <p>{{ article.summary }}</p>
        {%- endif %}
      </article>
      {% endfor %}
    </div>
  </section>
{%- endblock %}
