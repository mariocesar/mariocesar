<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% block title %}{% endblock %}</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="follow, index" />

  <link rel="stylesheet" href="/static/css/main.css" />
  <link rel="apple-touch-icon" href="/static/icons/icon-512.png"/>
  <link rel="icon" type="image/png" href="/static/icons/icon-16.png" sizes="16x16">
  <link rel="icon" type="image/png" href="/static/icons/icon-32.png" sizes="32x32">
  <link rel="icon" type="image/png" href="/static/icons/icon-48.png" sizes="48x48">

  <link rel="icon" type="image/png" href="/static/icons/icon-256.png" sizes="192x192">
  <link rel="icon" type="image/png" href="/static/icons/icon-512.png" sizes="512x512">

  <meta name="theme-color" content="#ffffff">
  <meta name="application-name" content="mariocesar.xyz">
  <meta name="msapplication-TileColor" content="#ffffff">
  <meta name="msapplication-TileImage" content="/static/icons/icon-256.png">
  <link rel="alternate" type="application/rss+xml" title="Mario-César Señoranis Articles" href="/articles/rss.xml">

  {% block extrahead %}{% endblock %}
</head>
<body>
  <header class="site-header">
    <a class="site-brand" href="/">mariocesar.xyz</a>
    <nav aria-label="Main navigation">
      <a href="/articles/">Articles</a>
      <a href="https://github.com/mariocesar" rel="noopener" target="_blank">GitHub</a>
    </nav>
  </header>
  <main role="main">
    {% block body -%}{% endblock %}
  </main>
  <footer class="site-footer">
    <a href="/llms.txt">llms.txt</a>
    <a href="/articles/rss.xml">RSS</a>
  </footer>
</body>
</html>
